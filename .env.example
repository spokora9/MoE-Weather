# MoE Weather Environment Configuration
# Copy this file to .env and fill in your API keys

# Server Configuration
PORT=3000
NODE_ENV=development

# API Keys (Optional - The app works without these using free APIs)
# These enable additional data sources for better accuracy

# OpenWeatherMap - https://openweathermap.org/api
# Free tier: 1,000 calls/day
OPENWEATHERMAP_API_KEY=

# WeatherAPI.com - https://www.weatherapi.com/
# Free tier: 1,000,000 calls/month
WEATHERAPI_KEY=

# Tomorrow.io - https://www.tomorrow.io/weather-api/
# Free tier: 500 calls/day
TOMORROW_IO_API_KEY=

# Note: Open-Meteo and NWS (US) are always available without API keys

# Sentry
SENTRY_DSN=

# Metrics
METRICS_TOKEN=
